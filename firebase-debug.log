[debug] [2025-10-08T11:22:43.691Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/atpp-rekrutacja-tpp/rulesets {"name":"projects/atpp-rekrutacja-tpp/rulesets/f9a2ff1d-f369-44ff-991d-c86d280a22d2","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n\n    // Dostęp do folderu z plikami CV (cv-files)\n    match /cv-files/{fileName} {\n      // ZEZWALAJ na utworzenie (zapis/upload) pliku przez każdego.\n      // Używamy tego do przesyłania CV z formularza.\n      allow create: if true;\n\n      // BLOKUJ odczyt, aktualizację i usuwanie dla wszystkich.\n      // Dostęp do plików będzie realizowany przez linki (download URLs),\n      // które mają własne, bezpieczne mechanizmy autoryzacji.\n      allow read, update, delete: if false;\n    }\n\n    // Dostęp do folderu z listami motywacyjnymi (lm-files)\n    match /lm-files/{fileName} {\n      // ZEZWALAJ na utworzenie (zapis/upload) pliku przez każdego.\n      allow create: if true;\n\n      // BLOKUJ odczyt, aktualizację i usuwanie dla wszystkich.\n      allow read, update, delete: if false;\n    }\n\n    // Domyślnie blokuj dostęp do wszystkich innych ścieżek w Storage.\n    match /{allPaths=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2025-10-08T11:22:43.602415Z","metadata":{"services":["firebase.storage"]}}
